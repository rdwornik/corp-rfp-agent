# --- Python artifacts ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.dll

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment / secrets
.env
*.env

# --- IDE / editor ---
.vscode/
.idea/
*.code-workspace
.claude/

# --- OS cruft ---
.DS_Store
Thumbs.db
desktop.ini

# --- Logs / cache ---
logs
logs/
*.log
.ipynb_checkpoints/
.pytest_cache/

# --- RFP INPUT / OUTPUT (customer data!) ---
data/input/
data/output/

# --- KB historical RFPs (customer data — never commit) ---
data/kb/historical/**/*.xlsx
data/kb/historical/**/*.xls
data/kb/historical/**/*.docx
data/kb/historical/**/*.pdf
data/kb/historical/**/processing/

# --- KB staging (intermediate review files — not for version control) ---
data/kb/staging/*.jsonl

# --- Archive (confidential — actual RFP files and raw extractions) ---
data/kb/archive/files/
data/kb/archive/extractions/
# Keep the registry — it contains no customer data (just metadata Rob controls)
!data/kb/archive/archive_registry.json

# --- Keep folder structure ---
!**/.gitkeep

# Legacy paths (in case of incomplete migration)
input_rfp/
input_rfp_test/
output_rfp_gemini/
output_rfp_gemini_test/
output_rfp_gemini_test_flagged
output_rfp_universal/
tmp_rfps_to_be_answered/

# --- KB data (raw + canonical) ---
# These files almost certainly contain sensitive/internal info.
# Keep them OUT of a public repo. If your GitHub repo is private
# and you want them versioned, comment these lines out.
data/kb/raw/
data/kb/canonical/
data/archive/

# Legacy paths
data_kb/raw/
data_kb/canonical/
data_kb/archive_canonical/

# --- KB per-entry files (contain answer content — treat like canonical) ---
data/kb/verified/
data/kb/drafts/
data/kb/rejected/
data/kb/feedback_log.jsonl
data/kb/.fb_counter

# --- Index sync state (machine-specific, generated) ---
data/kb/file_state.json
data/kb/file_state.tmp

# --- VECTOR DATABASE (Generated Artifact) ---
data/kb/chroma_store/
data_kb/chroma_store/

# Top-level KB working files & exports
RFP_Database_Cognitive_Planning*.csv
RFP_Database_Cognitive_Planning*.json
RFP_Database_Cognitive_Planning*.jsonl
RFP_Database_Cognitive_Planning*.xlsx

# --- Local helper lists (not needed in Git) ---
project_files.txt
project_tree.txt

# --- Test/debug scripts (temporary, root-level only) ---
/test_*.py
/debug_*.py
/*_test.py

# --- Ignore .github workflows in local dev ---
.github/

# --- Ignore maintenance scripts that have been deleted ---

# --- IGNORE ---
RFP_Cognitive_Agent_Documentation.docx
~$P_Cognitive_Agent_Documentation.docx
rfp_system_prompt_v*.txt

